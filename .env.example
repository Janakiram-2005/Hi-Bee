# UI-TARS Desktop — Environment Template
# Copy this to .env and fill in your real values.
# This file IS safe to commit — it contains NO real credentials.

# ── Google Vertex AI VLM Provider (GUI Automation) ───────────────────────────
VERTEX_VLM_PROJECT_ID=your-gcp-project-id
VERTEX_VLM_LOCATION=us-central1
VERTEX_VLM_MODEL_NAME=gemini-2.5-flash

# ── Vertex AI (Voice Assistant) ───────────────────────────────────────────────
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_SEARCH_ENGINE_ID=your-search-engine-id

# ── GCP Authentication ────────────────────────────────────────────────────────
# Set either GOOGLE_APPLICATION_CREDENTIALS or use ADC (recommended)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@host/db?retryWrites=true&w=majority

# ── Ollama (optional local LLM) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=180

# ── Alternative VLM providers (optional) ─────────────────────────────────────
# VLM_PROVIDER=
# VLM_BASE_URL=
# VLM_API_KEY=
# VLM_MODEL_NAME=

# ── Third-party API Keys (optional) ──────────────────────────────────────────
# GOOGLE_API_KEYS=
# GROQ_API_KEYS=
# OPENROUTER_API_KEYS=
# CEREBRAS_API_KEYS=

# ── ElevenLabs TTS (Primary Voice Output) ────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
